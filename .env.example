# ── Gemini AI ────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key_here"

# ── Twilio (Real OTP SMS - International) ────────────────────────
# Get free trial at https://twilio.com
# Free trial: $15 credit, works for India (+91)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# ── Fast2SMS (India-only, cheaper alternative to Twilio) ─────────
# Get API key at https://fast2sms.com (₹100 = 1000 SMS)
# Set USE_FAST2SMS=true to use Fast2SMS instead of Twilio
FAST2SMS_API_KEY="your_fast2sms_api_key"
USE_FAST2SMS=false

# ── WhatsApp (Twilio WhatsApp Sandbox) ───────────────────────────
# Enable at: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# Sandbox number: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
ENABLE_WHATSAPP=true

# ── App ───────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
PORT=5000
NODE_ENV=development

# ── JWT Secret ───────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ── Map (OpenStreetMap - FREE, no key needed) ────────────────────
# No API key required for OpenStreetMap / Leaflet
